# ══════════════════════════════════════════════════════
#  REQUIRED — system won't start without these
# ══════════════════════════════════════════════════════

# Google Places API — finds local businesses on Google Maps
# Get it: console.cloud.google.com → APIs & Services → Enable "Places API" → Credentials
GOOGLE_PLACES_API_KEY=your_key_here

# Anthropic — generates HTML landing pages with Claude
# Get it: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Supabase — stores all leads and pipeline data
# Get it: app.supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Instantly — sends your cold email campaigns
# Get it: app.instantly.ai → Settings → API
INSTANTLY_API_KEY=your_instantly_api_key_here

# Your campaign ID (run `npm run setup-campaign` to create one)
INSTANTLY_CAMPAIGN_ID=your_campaign_id_here

# Your email address (used in email footer)
SENDER_EMAIL=you@yourdomain.com
SENDER_NAME=Your Name


# ══════════════════════════════════════════════════════
#  OPTIONAL — enables automatic email discovery
#  Without these, leads are found but no email is searched for
# ══════════════════════════════════════════════════════

# Google Custom Search API — searches the web for contact emails
# Get it: console.cloud.google.com → Enable "Custom Search API" → Credentials
GOOGLE_SEARCH_API_KEY=your_key_here

# Custom Search Engine ID — must be set to search the entire web
# Get it: programmablesearchengine.google.com
#         → New Search Engine → "Search the entire web" → copy the ID
GOOGLE_SEARCH_CX=your_cx_here


# ══════════════════════════════════════════════════════
#  OPTIONAL — enables live hosted landing pages
#  Without this, pages are saved locally as HTML files
# ══════════════════════════════════════════════════════

# Netlify personal access token
# Get it: app.netlify.com → User Settings → Applications → Personal access tokens
NETLIFY_TOKEN=your_netlify_token_here


# ══════════════════════════════════════════════════════
#  SETTINGS
# ══════════════════════════════════════════════════════

# How many leads to scrape per city run (default: 60)
MAX_LEADS_PER_CITY=60

# Server port for the dashboard (default: 3000)
PORT=3000
